{
  "manifest_version": 3,
  "name": "Next API Capture",
  "version": "0.1.0",
  "description": "Inspect server (SSR/RSC) + client API calls of Next.js App Router apps in a DevTools panel.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "devtools_page": "src/devtools.html",
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": ["http://localhost/*", "http://127.0.0.1/*"],
  "content_scripts": [
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["src/relay.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
