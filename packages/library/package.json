{
  "name": "@shinjinseop/library",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./inject": {
      "types": "./dist/inject.d.ts",
      "import": "./dist/inject.js",
      "require": "./dist/inject.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "next": ">=13.4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@shinjinseop/shared": "workspace:*",
    "@types/node": "^20.16.11",
    "@types/react": "^19.0.2",
    "@types/ws": "^8.5.12",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
