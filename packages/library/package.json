{
  "name": "@shinjinseop/next-api-capture",
  "version": "0.1.1",
  "description": "Capture server-side (SSR/RSC, route handlers, server actions) and client API calls of a Next.js App Router app, and inspect them in a Chrome DevTools panel.",
  "license": "MIT",
  "author": "yeo11200",
  "homepage": "https://github.com/yeo11200/next-api-capture#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yeo11200/next-api-capture.git",
    "directory": "packages/library"
  },
  "bugs": {
    "url": "https://github.com/yeo11200/next-api-capture/issues"
  },
  "keywords": [
    "nextjs",
    "app-router",
    "rsc",
    "devtools",
    "fetch",
    "api",
    "capture",
    "debugging",
    "instrumentation"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./inject": {
      "types": "./dist/inject.d.ts",
      "import": "./dist/inject.js",
      "require": "./dist/inject.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "next": ">=13.4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true }
  },
  "devDependencies": {
    "@shinjinseop/shared": "workspace:*",
    "@types/node": "^20.16.11",
    "@types/react": "^19.0.2",
    "@types/ws": "^8.5.12",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
